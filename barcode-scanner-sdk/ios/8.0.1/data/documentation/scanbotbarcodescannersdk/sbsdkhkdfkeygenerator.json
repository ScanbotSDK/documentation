{"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@objcMembers","kind":"attribute"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SBSDKHKDFKeyGenerator","kind":"identifier"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This key generator has no randomization component. The key is solely derived from the input key material, the info data block and the salt."},{"type":"text","text":" "},{"type":"text","text":"Passing the identical input key material, salt and info data will always result in the same key."}]},{"name":"Note","type":"aside","content":[{"inlineContent":[{"text":"Use this key generator if you want to derive a key that is used to encrypt and decrypt your data in the same way every time,","type":"text"},{"text":" ","type":"text"},{"text":"regardless of the device, user or app session.","type":"text"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKHKDFKeyGenerator"},"metadata":{"title":"SBSDKHKDFKeyGenerator","roleHeading":"Class","modules":[{"name":"ScanbotBarcodeScannerSDK"}],"platforms":[{"introducedAt":"14.0","unavailable":false,"beta":false,"deprecated":false,"name":"iOS"},{"introducedAt":"14.0","unavailable":false,"beta":false,"deprecated":false,"name":"iPadOS"},{"introducedAt":"14.0","unavailable":false,"beta":false,"deprecated":false,"name":"Mac Catalyst"}],"externalID":"c:@M@ScanbotBarcodeScannerSDK@objc(cs)SBSDKHKDFKeyGenerator","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"