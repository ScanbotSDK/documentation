{"hierarchy":{"paths":[["doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK"]]},"abstract":[{"text":"Field validation status.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@objc","kind":"attribute"},{"text":"(SBSDKGenericDocumentFieldValidationStatus) ","kind":"text"},{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SBSDKGenericDocumentFieldValidationStatus","kind":"identifier"}],"platforms":["iOS"],"languages":["swift"]}]},{"content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Optical character recognition (OCR) invariably introduces errors in the recognized text.","type":"text"},{"text":" ","type":"text"},{"text":"There are numerous ways to verify that what has been recognized is, in fact, what was","type":"text"},{"text":" ","type":"text"},{"text":"written in the document.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The best way to validate the value of a field is for it to have a known format or validation","type":"text"},{"text":" ","type":"text"},{"text":"logic. For example, an IBAN number has a known format and two check digits that make it","type":"text"},{"text":" ","type":"text"},{"text":"very unlikely that a value with OCR errors will pass validation. Fields with known","type":"text"},{"text":" ","type":"text"},{"text":"validation rules will have a validation status of either VALID or INVALID.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Fields whose value can be inferred from other fields, or from domain knowledge (for example,","type":"text"},{"text":" ","type":"text"},{"text":"the field may have the same value in every instance of this type of document), will have the","type":"text"},{"text":" ","type":"text"},{"text":"status INFERRED. Inferring the value of a field is a strong validation method, provided that","type":"text"},{"text":" ","type":"text"},{"text":"there are no unexpected changes to the document format.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Fields that do not have validation rules and cannot be inferred can still be validated by checking whether the same","type":"text"},{"text":" ","type":"text"},{"text":"value is recognized from multiple attempts, e.g. across multiple frames of a camera stream.","type":"text"},{"text":" ","type":"text"},{"text":"If the same value is recognized in multiple frames, the value is considered CONFIRMED, otherwise","type":"text"},{"text":" ","type":"text"},{"text":"it will have the status NONE. This is the least strict validation method, as it does not protect","type":"text"},{"text":" ","type":"text"},{"text":"from systemic OCR errors, but in practice it still provides good results for most fields.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKGenericDocumentFieldValidationStatus","interfaceLanguage":"swift"},"kind":"symbol","topicSections":[{"generated":true,"identifiers":["doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKGenericDocumentFieldValidationStatus\/rawValue"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKGenericDocumentFieldValidationStatus\/confirmed","doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKGenericDocumentFieldValidationStatus\/ignored","doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKGenericDocumentFieldValidationStatus\/inferred","doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKGenericDocumentFieldValidationStatus\/invalid","doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKGenericDocumentFieldValidationStatus\/none","doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKGenericDocumentFieldValidationStatus\/obstructed","doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKGenericDocumentFieldValidationStatus\/valid"],"anchor":"Type-Properties","title":"Type Properties"},{"generated":true,"identifiers":["doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/documentation\/ScanbotBarcodeScannerSDK\/SBSDKGenericDocumentFieldValidationStatus\/enumValue(from:)"],"anchor":"Type-Methods","title":"Type Methods"}],"variants":[{"paths":["\/documentation\/scanbotbarcodescannersdk\/sbsdkgenericdocumentfieldvalidationstatus"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/scanbotbarcodescannersdk\/sbsdkgenericdocumentfieldvalidationstatus"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SBSDKGenericDocumentFieldValidationStatus","kind":"identifier"}],"navigatorTitle":[{"text":"SBSDKGenericDocumentFieldValidationStatus","kind":"identifier"}],"symbolKind":"class","roleHeading":"Class","role":"symbol","title":"SBSDKGenericDocumentFieldValidationStatus","externalID":"c:@M@ScanbotBarcodeScannerSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus","modules":[{"name":"ScanbotBarcodeScannerSDK"}]},"relationshipsSections":[{"identifiers":["doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/objc(cs)NSObject"],"kind":"relationships","type":"inheritsFrom","title":"Inherits From"},{"identifiers":["doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/objc(pl)NSObject","doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/s7CVarArgP","doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/s28CustomDebugStringConvertibleP","doc:\/\/net.doo.ScanbotBarcodeScannerSDK\/s23CustomStringConvertibleP","doc:\/\/net.doo.ScanbotBarcodeSc