,"text":"Field value failed validation. This status is used for fields that have validation rules, like"},{"text":" ","type":"text"},{"text":"IBAN, date fields, etc. that have check digits or a known format that can be validated.","type":"text"}],"role":"symbol","kind":"symbol","title":"invalid","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"invalid"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus","kind":"typeIdentifier","text":"SBSDKGenericDocumentFieldValidationStatus"}],"navigatorTitle":[{"kind":"identifier","text":"invalid"}]},"doc://net.doo.ScanbotSDK/SH":{"identifier":"doc:\/\/net.doo.ScanbotSDK\/SH","type":"unresolvable","title":"Swift.Hashable"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/none":{"type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"none"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus","kind":"typeIdentifier","text":"SBSDKGenericDocumentFieldValidationStatus"}],"navigatorTitle":[{"kind":"identifier","text":"none"}],"identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/none","title":"none","abstract":[{"type":"text","text":"Field value was not validated, typically because the field does not support validation and the value"},{"text":" ","type":"text"},{"text":"has not been seen enough times to confirm it.","type":"text"},{"text":" ","type":"text"},{"text":"If the same value is seen in multiple frames, the validation status will transition to CONFIRMED,","type":"text"},{"text":" ","type":"text"},{"text":"but only if that particular recognizer supports multiple frame accumulation.","type":"text"}],"role":"symbol","kind":"symbol","url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/none"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/ignored":{"identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/ignored","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"ignored"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus","kind":"typeIdentifier","text":"SBSDKGenericDocumentFieldValidationStatus"}],"navigatorTitle":[{"kind":"identifier","text":"ignored"}],"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"The document contains a field of this type, but recognition for this field is disabled."},{"text":" ","type":"text"},{"text":"The value of this field is always empty, although the field may be non-empty in the document.","type":"text"}],"title":"ignored","url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/ignored","role":"symbol"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/inferred":{"title":"inferred","url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/inferred","type":"topic","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/inferred","navigatorTitle":[{"kind":"identifier","text":"inferred"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"inferred"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus","kind":"typeIdentifier","text":"SBSDKGenericDocumentFieldValidationStatus"}],"abstract":[{"type":"text","text":"Field value was inferred from other fields or from domain knowledge."},{"type":"text","text":" "},{"text":"The field value may differ from what is actually written in the document in unexpected situations.","type":"text"}]},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/obstructed":{"abstract":[{"type":"text","text":"Field value was not recognized because it was obstructed by e.g. a light reflection or a shadow."}],"role":"symbol","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/obstructed","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"obstructed"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus","text":"SBSDKGenericDocumentFieldValidationStatus"}],"navigatorTitle":[{"kind":"identifier","text":"obstructed"}],"type":"topic","title":"obstructed","url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/obstructed","kind":"symbol"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/enumValue(from:)":{"abstract":[{"type":"text","text":"Returns an instance of "},{"type":"reference","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus","isActive":true},{"type":"text","text":" based on the provided raw value."}],"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"enumValue"},{"kind":"text","text":"("},{"kind":"externalParam","text":"from"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":") -> "},{"ki