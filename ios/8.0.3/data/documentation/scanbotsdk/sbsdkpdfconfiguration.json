":"codeVoice"},{"text":" is the conversion ratio used","type":"text"},{"text":" ","type":"text"},{"text":"to convert from units of pixels to physical inches when adding bitmap images (JPEG, PNG, or","type":"text"},{"text":" ","type":"text"},{"text":"raw) to the PDF. Otherwise, if ","type":"text"},{"code":"resamplingMethod","type":"codeVoice"},{"text":" is not NONE, then the image is downscaled","type":"text"},{"text":" ","type":"text"},{"text":"if necessary (if the image after being fit to the page has a higher calculated DPI than","type":"text"},{"text":" ","type":"text"},{"code":"dpi","type":"codeVoice"},{"text":") to match ","type":"text"},{"code":"dpi","type":"codeVoice"},{"text":" before adding it to the PDF. Otherwise, the setting is ignored and the","type":"text"},{"text":" ","type":"text"},{"text":"calculated image DPI is used instead.","type":"text"}],"url":"\/documentation\/scanbotsdk\/sbsdkpdfconfiguration\/dpi","kind":"symbol","navigatorTitle":[{"text":"dpi","kind":"identifier"}]},"doc://net.doo.ScanbotSDK/SQ":{"title":"Swift.Equatable","identifier":"doc:\/\/net.doo.ScanbotSDK\/SQ","type":"unresolvable"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK":{"title":"ScanbotSDK","abstract":[{"type":"text","text":"Version: 8.0.3"}],"kind":"symbol","role":"collection","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK","type":"topic","url":"\/documentation\/scanbotsdk"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKPDFConfiguration/init()":{"title":"init()","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKPDFConfiguration\/init()","abstract":[],"url":"\/documentation\/scanbotsdk\/sbsdkpdfconfiguration\/init()","role":"symbol","navigatorTitle":[{"text":"init","kind":"identifier"}],"type":"topic","fragments":[{"text":"init","kind":"identifier"},{"text":"()","kind":"text"}],"kind":"symbol"},"doc://net.doo.ScanbotSDK/objc(pl)NSObject":{"identifier":"doc:\/\/net.doo.ScanbotSDK\/objc(pl)NSObject","type":"unresolv