{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@objc","kind":"attribute"},{"text":"(SBSDKPDFConfiguration) ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SBSDKPDFConfiguration","kind":"identifier"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pageSize"},{"type":"text","text":" is "},{"type":"codeVoice","code":"CUSTOM"},{"type":"text","text":":"},{"type":"text","text":" "},{"type":"text","text":"in this case "},{"type":"codeVoice","code":"dpi"},{"type":"text","text":" is used as the conversion ratio to calculate both the physical page and"},{"type":"text","text":" "},{"type":"text","text":"image sizes in inches from the bitmap dimensions. "},{"type":"codeVoice","code":"resamplingMethod"},{"type":"text","text":" is ignored."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pageSize"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"CUSTOM"},{"type":"text","text":" AND "},{"type":"codeVoice","code":"pageFit"},{"type":"text","text":" is "},{"type":"codeVoice","code":"NONE"},{"type":"text","text":":"},{"type":"text","text":" "},{"type":"text","text":"in this case "},{"type":"codeVoice","code":"dpi"},{"type":"text","text":" is used as the conversion ratio to calculate only the physical image"},{"type":"text","text":" "},{"type":"text","text":"size in inches from the bitmap dimensions. The image is centered onto the page."},{"type":"text","text":" "},{"type":"codeVoice","code":"resamplingMethod"},{"type":"text","text":" is ignored."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"pageSize","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"CUSTOM","type":"codeVoice"},{"text":" AND ","type":"text"},{"code":"pageFit","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"NONE","type":"codeVoice"},{"text":":","type":"text"},{"text":" ","type":"text"},{"text":"in this case the page has a pre-determined physical size and we want to stretch the image to","type":"text"},{"text":" ","type":"text"},{"text":"fit the page in one of the ways described by ","type":"text"},{"code":"pageFit","type":"codeVoice"},{"text":". The image DPI is automatically","type":"text"},{"text":" ","type":"text"},{"text":"calculated for each image from the given physical page size, page fit setting and image","type":"text"},{"text":" ","type":"text"},{"text":"dimensions. There are two sub-cases to consider:","type":"text"},{"text":" ","type":"text"},{"text":"a. ","type":"text"},{"code":"resamplingMethod","type":"codeVoice"},{"text":" is NONE OR the calculated DPI is less than or equal to ","type":"text"},{"code":"dpi","type":"codeVoice"},{"text":":","type":"text"},{"text":" ","type":"text"},{"text":"in this case the image is added to the PDF without resampling, which means that the image","type":"text"},{"text":" ","type":"text"},{"text":"rectangle is simply rescaled to fit into the page as specified by ","type":"text"},{"code":"pageFit","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"pageSize","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"b. ","type":"text"},{"code":"resamplingMethod","type":"codeVoice"},{"text":" is not NONE AND the calculated DPI is greater than ","type":"text"},{"code":"dpi","type":"codeVoice"},{"text":":","type":"text"},{"text":" ","type":"text"},{"text":"in this case the bitmap of the image is resampled to match ","type":"text"},{"code":"dpi","type":"codeVoice"},{"text":" using the selected method","type":"text"},{"text":" ","type":"text"},{"text":"before adding it to the PDF. This will result in a bitmap that is smaller than the","type":"text"},{"text":" ","type":"text"},{"text":"original image and hence, the resulting PDF will be smaller in size.","type":"text"}]}]}],"type":"orderedList"}]}],"variants":[{"paths":["\/documentation\/scanbotsdk\/sbsdkpdfconfiguration"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/scanbotsdk\/sbsdkpdfconfiguration"],"traits":[{"interfaceLanguage":"occ"}]}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/net.doo.ScanbotSDK\/objc(cs)NSObject"],"type":"inheritsFrom","title":"Inherits From"},{"kind":"relationships","identifiers":["doc:\/\/net.doo.ScanbotSDK\/objc(pl)NSCopying","doc:\/\/net.doo.ScanbotSDK\/objc(pl)NSObject","doc:\/\/net.doo.ScanbotSDK\/s7CVarArgP","doc:\/\/net.doo.ScanbotSDK\/s28CustomDebugStringConvertibleP","doc:\/\/net.doo.ScanbotSDK\/s23CustomStringConvertibleP","doc:\/\/net.doo.ScanbotSDK\/Se","doc:\/\/net.doo.ScanbotSDK\/SE","doc:\/\/net.doo.ScanbotSDK\/SQ","doc:\/\/net.doo.ScanbotSDK\/SH"],"type":"conformsTo","title":"Conforms To"}],"sections":[],"metadata":{"navigatorTitle":[{"text":"SBSDKPDFConfiguration","kind":"identifier"}],"title":"SBSDKPDFConfiguration","roleHeading":"Class","symbolKind":"class","modules":[{"name":"ScanbotSDK"}],"externalID":"c:@M@ScanbotSDK@objc(cs)SBSDKPDFConfiguration","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SBSDKPDFConfiguration"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKPDFConfiguration"},"abstract":[{"text":"The parameters ","type":"text"},{"code":"pageSize","type":"codeVoice"},{"text":", ","type":"text"},{"code":"pageFit","type":"codeVoice"},{"text":", ","type":"text"},{"code":"dpi","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"resamplingMethod","type":"codeVoice"},{"text":" interact in a complex way","type":"text"},{"text":" ","type":"text"},{"text":"when adding bitmap images (JPEG, PNG, or raw) to the PDF.","type":"text"},{"text":" ","type":"text"},{"text":"There are three cases to consider:","type":"te