ntifier":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus"}],"identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/inferred","kind":"symbol","title":"inferred","url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/inferred","navigatorTitle":[{"kind":"identifier","text":"inferred"}],"abstract":[{"type":"text","text":"Field value was inferred from other fields or from domain knowledge."},{"type":"text","text":" "},{"type":"text","text":"The field value may differ from what is actually written in the document in unexpected situations."}],"role":"symbol","type":"topic"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/confirmed":{"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"confirmed"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"SBSDKGenericDocumentFieldValidationStatus","preciseIdentifier":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus"}],"role":"symbol","url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/confirmed","kind":"symbol","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/confirmed","navigatorTitle":[{"kind":"identifier","text":"confirmed"}],"type":"topic","title":"confirmed","abstract":[{"text":"The same field value was recognized in multiple frames, thereby confirming the value.","type":"text"},{"text":" ","type":"text"},{"text":"Occurs only for fields that have no validation rules otherwise.","type":"text"},{"text":" ","type":"text"},{"text":"A CONFIRMED value gives a strong guarantee that the field value has been read out without errors,","type":"text"},{"text":" ","type":"text"},{"text":"but not as strong as VALID. The value may still be incorrect, due to systemic OCR errors.","type":"text"},{"text":" ","type":"text"},{"text":"In case of OCR errors, increase the number of frames needed to confirm the value in the","type":"text"},{"text":" ","type":"text"},{"text":"recognizer configuration.","type":"text"}]},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/rawValue":{"navigatorTitle":[{"kind":"identifier","text":"rawValue"}],"type":"topic","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/rawValue","role":"symbol","abstract":[{"text":"The raw value integer of the current ","type":"text"},{"identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus","type":"reference","isActive":true},{"text":".","type":"text"}],"title":"rawValue","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"rawValue"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"kind":"symbol","url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/rawvalue"},"doc://net.doo.ScanbotSDK/SH":{"title":"Swift.Hashable","type":"unresolvable","identifier":"doc:\/\/net.doo.ScanbotSDK\/SH"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/none":{"url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/none","navigatorTitle":[{"kind":"identifier","text":"none"}],"kind":"symbol","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/none","abstract":[{"type":"text","text":"Field value was not validated, typically because the field does not support validation and the value"},{"type":"text","text":" "},{"type":"text","text":"has not been seen enough times to confirm it."},{"type":"text","text":" "},{"type":"text","text":"If the same value is seen in multiple frames, the validation status will tra