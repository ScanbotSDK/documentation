{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus"},"metadata":{"title":"SBSDKGenericDocumentFieldValidationStatus","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SBSDKGenericDocumentFieldValidationStatus"}],"navigatorTitle":[{"kind":"identifier","text":"SBSDKGenericDocumentFieldValidationStatus"}],"modules":[{"name":"ScanbotSDK"}],"roleHeading":"Class","symbolKind":"class","externalID":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus"},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/net.doo.ScanbotSDK\/objc(cs)NSObject"],"type":"inheritsFrom","title":"Inherits From"},{"kind":"relationships","identifiers":["doc:\/\/net.doo.ScanbotSDK\/objc(pl)NSObject","doc:\/\/net.doo.ScanbotSDK\/s7CVarArgP","doc:\/\/net.doo.ScanbotSDK\/s28CustomDebugStringConvertibleP","doc:\/\/net.doo.ScanbotSDK\/s23CustomStringConvertibleP","doc:\/\/net.doo.ScanbotSDK\/Se","doc:\/\/net.doo.ScanbotSDK\/SE","doc:\/\/net.doo.ScanbotSDK\/SQ","doc:\/\/net.doo.ScanbotSDK\/SH"],"type":"conformsTo","title":"Conforms To"}],"topicSections":[{"identifiers":["doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/rawValue"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"identifiers":["doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/confirmed","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/ignored","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/inferred","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/invalid","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/none","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/obstructed","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/valid"],"anchor":"Type-Properties","generated":true,"title":"Type Properties"},{"identifiers":["doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/enumValue(from:)"],"anchor":"Type-Methods","generated":true,"title":"Type Methods"}],"abstract":[{"type":"text","text":"Field validation status."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus"]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@objc"},{"kind":"text","text":"(SBSDKGenericDocumentFieldValidationStatus) "},{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SBSDKGenericDocumentFieldValidationStatus"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Optical character recognition (OCR) invariably introduces errors in the recognized text.","type":"text"},{"text":" ","type":"text"},{"text":"There are numerous ways to verify that what has been recognized is, in fact, what was","type":"text"},{"text":" ","type":"text"},{"text":"written in the document.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The best way to validate the value of a field is for it to have a known format or validation"},{"type":"text","text":" "},{"type":"text","text":"logic. For example, an IBAN number has a known format and two check digits that make it"},{"type":"text","text":" "},{"type":"text","text":"very unlikely that a value with OCR errors will pass validation. Fields with known"},{"type":"text","text":" "},{"type":"text","text":"validation rules will have a validation status of either VALID or INVALID."}]},{"type":"paragraph","inlineContent":[{"text":"Fields whose value can be inferred from other fields, or from domain knowledge (for example,","type":"text"},{"text":" ","type":"text"},{"text":"the field may have the same value in every instance of this type of document), will have the","type":"text"},{"text":" ","type":"text"},{"text":"status INFERRED. Inferring the value of a field is a strong validation method, provided that","type":"text"},{"text":" ","type":"text"},{"text":"there are no unexpected changes to the document format.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Fields that do not have validation rules and cannot be inferred can still be validated by checking whether the same","type":"text"},{"text":" ","type":"text"},{"text":"value is recognized from multiple attempts, e.g. across multiple frames of a camera stream.","type":"text"},{"text":" ","type":"text"},{"text":"If the same value is recognized in multiple frames, the value is considered CONFIRMED, otherwise","type":"text"},{"text":" ","type":"text"},{"text":"it will have the status NONE. This is the least strict validation method, as it does not protect","type":"text"},{"text":" ","type":"text"},{"text":"from systemic OCR errors, but in practice it still provides good results for most fields.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK"]]},"references":{"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/hash":{"identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/hash","title":"hash","role":"symbol","typ