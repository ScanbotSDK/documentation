{"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKOneDConfirmationMode"]]},"identifier":{"url":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKOneDConfirmationMode\/moderate","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"moderate"}]}],"kind":"declarations"}],"metadata":{"roleHeading":"Case","externalID":"c:@M@ScanbotSDK@E@SBSDKOneDConfirmationMode@SBSDKOneDConfirmationModeModerate","role":"symbol","modules":[{"name":"ScanbotSDK"}],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"moderate"}],"navigatorTitle":[{"text":"SBSDKOneDConfirmationModeModerate","kind":"identifier"}],"title":"SBSDKOneDConfirmationMode.moderate","symbolKind":"case"},"abstract":[{"text":"Moderate confirmation is performed. Compared to minimal confirmation, it provides an additional decrease in false positives, at the cost of a slight decrease in recall.","type":"text"}],"variants":[{"paths":["\/documentation\/scanbotsdk\/sbsdkonedconfirmationmode\/moderate"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/scanbotsdk\/sbsdkonedconfirmationmode\/moderate"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKOneDConfirmationMode/moderate":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"moderate","kind":"identifier"}],"navigatorTitle":[{"text":"SBSDKOneDConfirmationModeModerate","kind":"identifier"}],"title":"SBSDKOneDConfirmationMode.moderate","abstract":[{"text":"Moderate confirmation is performed. Compared to minimal confirmation, it provides an additional decrease in false positives, at