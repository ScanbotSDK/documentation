 centered onto the page.","type":"text"},{"text":" ","type":"text"},{"code":"resamplingMethod","type":"codeVoice"},{"text":" is ignored.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"pageSize"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"CUSTOM"},{"text":" AND ","type":"text"},{"type":"codeVoice","code":"pageFit"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"NONE"},{"text":":","type":"text"},{"text":" ","type":"text"},{"text":"in this case the page has a pre-determined physical size and we want to stretch the image to","type":"text"},{"text":" ","type":"text"},{"text":"fit the page in one of the ways described by ","type":"text"},{"type":"codeVoice","code":"pageFit"},{"text":". The image DPI is automatically","type":"text"},{"text":" ","type":"text"},{"text":"calculated for each image from the given physical page size, page fit setting and image","type":"text"},{"text":" ","type":"text"},{"text":"dimensions. There are two sub-cases to consider:","type":"text"},{"text":" ","type":"text"},{"text":"a. ","type":"text"},{"type":"codeVoice","code":"resamplingMethod"},{"text":" is NONE OR the calculated DPI is less than or equal to ","type":"text"},{"type":"codeVoice","code":"dpi"},{"text":":","type":"text"},{"text":" ","type":"text"},{"text":"in this case the image is added to the PDF without resampling, which means that the image","type":"text"},{"text":" ","type":"text"},{"text":"rectangle is simply rescaled to fit into the page as specified by ","type":"text"},{"type":"codeVoice","code":"pageFit"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"pageSize"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"b. ","type":"text"},{"type":"codeVoice","code":"resamplingMethod"},{"text":" is not NONE AND the calculated DPI is greater than ","type":"text"},{"type":"codeVoice","code":"dpi"},{"text":":","type":"text"},{"text":" ","type":"text"},{"text":"in this case the bitmap of the image is resampled to match ","type":"text"},{"type":"codeVoice","code":"dpi"},{"text":" using the selected method","type":"text"},{"text":" ","type":"text"},{"text":"before adding it to the PDF. This will result in a bitmap that is smaller than the","type":"text"},{"text":" ","type":"text"},{"text":"original image and hence, the resulting PDF will be smaller in size.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/scanbotsdk\/sbsdkpdfconfiguration"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/scanbotsdk\/sbsdkpdfconfiguration"]}],"relationshipsSections":[{"title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/net.doo.ScanbotSDK\/objc(cs)NSObject"],"type":"inheritsFrom"},{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/net.doo.ScanbotSDK\/objc(pl)NSCopying","doc:\/\/net.doo.ScanbotSDK\/objc(pl)NSObject","doc:\/\/net.doo.ScanbotSDK\/s7CVarArgP","doc:\/\/net.doo.ScanbotSDK\/s28CustomDebugStringConvertibleP","doc:\/\/net.doo.ScanbotSDK\/s23CustomStringConvertibleP","doc:\/\/net.doo.ScanbotSDK\/Se","doc:\/\/net.doo.ScanbotSDK\/SE","doc:\/\/net.doo.ScanbotSDK\/SQ","doc:\/\/net.doo.ScanbotSDK\/SH"],"type":"conformsTo"}],"kind":"symbol","references":{"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK":{"url":"\/documentation\/scanbotsdk","kind":"symbol","abstract":[{"text":"Version: 8.0.4","type":"text"}],"identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK","type":"topic","role":"collection","title":"ScanbotSDK"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKPDFConfiguration/init()":{"navigatorTitle":[{"text":"init","kind":"identifier"}],"role":"symbol","kind":"symbol","url":"\/documentation\/scanbotsdk\/sbsdkpdfconfiguration\/init()","type":"topic","abstract":[],"identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKP