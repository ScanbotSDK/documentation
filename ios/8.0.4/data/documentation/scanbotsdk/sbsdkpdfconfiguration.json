n "},{"type":"codeVoice","code":"dpi"},{"type":"text","text":" is the conversion ratio used"},{"type":"text","text":" "},{"type":"text","text":"to convert from units of pixels to physical inches when adding bitmap images (JPEG, PNG, or"},{"type":"text","text":" "},{"type":"text","text":"raw) to the PDF. Otherwise, if "},{"type":"codeVoice","code":"resamplingMethod"},{"type":"text","text":" is not NONE, then the image is downscaled"},{"type":"text","text":" "},{"type":"text","text":"if necessary (if the image after being fit to the page has a higher calculated DPI than"},{"type":"text","text":" "},{"type":"codeVoice","code":"dpi"},{"type":"text","text":") to match "},{"type":"codeVoice","code":"dpi"},{"type":"text","text":" before adding it to the PDF. Otherwise, the setting is ignored and the"},{"type":"text","text":" "},{"type":"text","text":"calculated image DPI is used instead."}],"kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"dpi","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"url":"\/documentation\/scanbotsdk\/sbsdkpdfconfiguration\/dpi","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKPDFConfiguration\/dpi","title":"dpi","type":"topic","role":"symbol","navigatorTitle":[{"text":"dpi","kind":"identifier"}]},"doc://net.doo.ScanbotSDK/objc(pl)NSObject":{"identifier":"doc:\/\/net.doo.ScanbotSDK\/objc(pl)NSObject","title":"ObjectiveC.NSObjectProtocol","type":"unresolvable"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKPDFConfiguration/initWithAttributes:pageSize:pageDirection:pageFit:dpi:jpegQuality:resamplingMethod:binarizationFilter:":{"role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithAttributes:pageSize:pageDirection:pageFit:dpi:jpegQuality:resamplingMethod:binarizationFilter:","kind":"identifier"}],"url":"\/documentation\/scanbotsdk\/sbsdkpdfconfiguration\/initwithattributes:pagesize:p