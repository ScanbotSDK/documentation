{"relationshipsSections":[{"identifiers":["doc:\/\/net.doo.ScanbotSDK\/objc(cs)NSObject"],"type":"inheritsFrom","kind":"relationships","title":"Inherits From"},{"identifiers":["doc:\/\/net.doo.ScanbotSDK\/objc(pl)NSObject","doc:\/\/net.doo.ScanbotSDK\/s7CVarArgP","doc:\/\/net.doo.ScanbotSDK\/s28CustomDebugStringConvertibleP","doc:\/\/net.doo.ScanbotSDK\/s23CustomStringConvertibleP","doc:\/\/net.doo.ScanbotSDK\/Se","doc:\/\/net.doo.ScanbotSDK\/SE","doc:\/\/net.doo.ScanbotSDK\/SQ","doc:\/\/net.doo.ScanbotSDK\/SH"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/rawValue"]},{"generated":true,"anchor":"Type-Properties","title":"Type Properties","identifiers":["doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/confirmed","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/ignored","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/inferred","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/invalid","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/none","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/obstructed","doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/valid"]},{"generated":true,"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/enumValue(from:)"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@objc","kind":"attribute"},{"text":"(SBSDKGenericDocumentFieldValidationStatus) ","kind":"text"},{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SBSDKGenericDocumentFieldValidationStatus","kind":"identifier"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"Optical character recognition (OCR) invariably introduces errors in the recognized text.","type":"text"},{"text":" ","type":"text"},{"text":"There are numerous ways to verify that what has been recognized is, in fact, what was","type":"text"},{"text":" ","type":"text"},{"text":"written in the document.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The best way to validate the value of a field is for it to have a known format or validation","type":"text"},{"text":" ","type":"text"},{"text":"logic. For example, an IBAN number has a known format and two check digits that make it","type":"text"},{"text":" ","type":"text"},{"text":"very unlikely that a value with OCR errors will pass validation. Fields with known","type":"text"},{"text":" ","type":"text"},{"text":"validation rules will have a validation status of either VALID or INVALID.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Fields whose value can be inferred from other fields, or from domain knowledge (for example,","type":"text"},{"text":" ","type":"text"},{"text":"the field may have the same value in every instance of this type of document), will have the","type":"text"},{"text":" ","type":"text"},{"text":"status INFERRED. Inferring the value of a field is a strong validation method, provided that","type":"text"},{"text":" ","type":"text"},{"text":"there are no unexpected changes to the document format.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Fields that do not have validation rules and cannot be inferred can still be validated by checking whether the same"},{"text":" ","type":"text"},{"text":"value is recognized from multiple attempts, e.g. across multiple frames of a camera stream.","type":"text"},{"text":" ","type":"text"},{"text":"If the same value is recognized in multiple frames, the value is considered CONFIRMED, otherwise","type":"text"},{"text":" ","type":"text"},{"text":"it will have the status NONE. This is the least strict validation method, as it does not protect","type":"text"},{"text":" ","type":"text"},{"text":"from systemic OCR errors, but in practice it still provides good results for most fields.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK"]]},"metadata":{"title":"SBSDKGenericDocumentFieldValidationStatus","symbolKind":"class","roleHeading":"Class","externalID":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus","role":"symbol","modules":[{"name":"ScanbotSDK"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SBSDKGenericDocumentFieldValidationStatus"}],"navigatorTitle":[{"text":"SBSDKGenericDocumentFieldValidationStatus","kind":"identifier"}]},"sections":[],"abstract":[{"type":"text","text":"Field validation status."}],"references":{"doc://net.doo.ScanbotSDK/s23CustomStringConvertibleP":{"type":"unresolvable","title":"Swift.CustomStringConvertible","identifier":"doc:\/\/net.doo.ScanbotSDK\/s23CustomStringConvertibleP"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/none":{"title":"none","url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/none","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"none"}],"abstract":[{"text":"Field value was not validated, typically because the field does not support validation and the value","type":"text"},{"text":" ","type":"text"},{"text":"has not been seen enough times to confirm it.","type":"text"},{"text":" ","type":"text"},{"text":"If the same value is seen in multiple frames, the validation status will transition to CONFIRMED,","type":"text"},{"text":" ","type":"text"},{"text":"but only if that particular recognizer supports multiple frame accumulation.","type":"text"}],"identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/none","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"none"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus","text":"SBSDKGenericDocumentFieldValidationStatus"}],"kind":"symbol","type":"topic"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/enumValue(from:)":{"title":"enumValue(from:)","url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/enumvalue(from:)","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/enumValue(from:)","role":"symbol","abstract":[{"type":"text","text":"Returns an instance of "},{"type":"reference","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus","isActive":true},{"type":"text","text":" based on the provided raw value."}],"kind":"symbol","navigatorTitle":[{"text":"enumValueFrom:","kind":"identifier"}],"type":"topic","fragments":[{