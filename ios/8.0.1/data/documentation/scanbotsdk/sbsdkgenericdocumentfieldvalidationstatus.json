l transition to CONFIRMED,"},{"type":"text","text":" "},{"type":"text","text":"but only if that particular recognizer supports multiple frame accumulation."}],"role":"symbol"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/obstructed":{"url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/obstructed","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"obstructed","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SBSDKGenericDocumentFieldValidationStatus","kind":"typeIdentifier","preciseIdentifier":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus"}],"role":"symbol","type":"topic","title":"obstructed","abstract":[{"text":"Field value was not recognized because it was obstructed by e.g. a light reflection or a shadow.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/obstructed","navigatorTitle":[{"kind":"identifier","text":"obstructed"}]},"doc://net.doo.ScanbotSDK/SE":{"type":"unresolvable","identifier":"doc:\/\/net.doo.ScanbotSDK\/SE","title":"Swift.Encodable"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/inferred":{"abstract":[{"type":"text","text":"Field value was inferred from other fields or from domain knowledge."},{"type":"text","text":" "},{"type":"text","text":"The field value may differ from what is actually written in the document in unexpected situations."}],"type":"topic","kind":"symbol","url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/inferred","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"inferred","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SBSDKGenericDocumentFieldValidationStatus","kind"