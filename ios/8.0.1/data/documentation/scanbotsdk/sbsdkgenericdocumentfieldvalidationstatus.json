KGenericDocumentFieldValidationStatus","text":"SBSDKGenericDocumentFieldValidationStatus","kind":"typeIdentifier"},{"text":"?","kind":"text"}]},"doc://net.doo.ScanbotSDK/SQ":{"identifier":"doc:\/\/net.doo.ScanbotSDK\/SQ","type":"unresolvable","title":"Swift.Equatable"},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKGenericDocumentFieldValidationStatus/confirmed":{"type":"topic","kind":"symbol","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKGenericDocumentFieldValidationStatus\/confirmed","abstract":[{"text":"The same field value was recognized in multiple frames, thereby confirming the value.","type":"text"},{"text":" ","type":"text"},{"text":"Occurs only for fields that have no validation rules otherwise.","type":"text"},{"text":" ","type":"text"},{"text":"A CONFIRMED value gives a strong guarantee that the field value has been read out without errors,","type":"text"},{"text":" ","type":"text"},{"text":"but not as strong as VALID. The value may still be incorrect, due to systemic OCR errors.","type":"text"},{"text":" ","type":"text"},{"text":"In case of OCR errors, increase the number of frames needed to confirm the value in the","type":"text"},{"text":" ","type":"text"},{"text":"recognizer configuration.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"confirmed"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"SBSDKGenericDocumentFieldValidationStatus","preciseIdentifier":"c:@M@ScanbotSDK@objc(cs)SBSDKGenericDocumentFieldValidationStatus"}],"url":"\/documentation\/scanbotsdk\/sbsdkgenericdocumentfieldvalidationstatus\/confirmed","title":"confirmed","navigatorTitle":[{"kind":"identifier","text":"confirmed"}]},"doc://net.doo.ScanbotSDK/s7CVarArgP":{"title":"Swift.CVarArg","identifier":"doc:\/\/net.doo.ScanbotSDK\/s7CVarArgP","type":"unresolvable"},"doc://net.doo.ScanbotSDK