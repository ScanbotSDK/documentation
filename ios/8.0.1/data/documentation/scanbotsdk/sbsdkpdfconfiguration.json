t":"."},{"type":"text","text":" "},{"type":"text","text":"The image can either be stretched to fill the page,"},{"type":"text","text":" "},{"type":"text","text":"in one of three ways, or centered on the page without stretching."}],"title":"pageFit","type":"topic","identifier":"doc:\/\/net.doo.ScanbotSDK\/documentation\/ScanbotSDK\/SBSDKPDFConfiguration\/pageFit","role":"symbol","navigatorTitle":[{"text":"pageFit","kind":"identifier"}]},"doc://net.doo.ScanbotSDK/documentation/ScanbotSDK/SBSDKPDFConfiguration/dpi":{"abstract":[{"type":"text","text":"The "},{"code":"dpi","type":"codeVoice"},{"type":"text","text":" parameter has two different meanings depending on the value of "},{"code":"pageSize","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"pageFit","type":"codeVoice"},{"type":"text","text":". If pageSize is CUSTOM or pageFit is NONE, then "},{"code":"dpi","type":"codeVoice"},{"type":"text","text":" is the conversion ratio used"},{"type":"text","text":" "},{"type":"text","text":"to convert from units of pixels to physical inches when adding bitmap images (JPEG, PNG, or"},{"type":"text","text":" "},{"text":"raw) to the PDF. Otherwise, if ","type":"text"},{"code":"resamplingMethod","type":"codeVoice"},{"text":" is not NONE, then the image is downscaled","type":"text"},{"text":" ","type":"text"},{"text":"if necessary (if the image after being fit to the page has a higher calculated DPI than","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"dpi"},{"text":") to match ","type":"text"},{"type":"codeVoice","code":"dpi"},{"text":" before adding it to the PDF. Otherwise, the setting is ignored and the","type":"text"},{"text":" ","type":"text"},{"text":"calculated image DPI is used instead.","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"dpi","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"url":"\/doc