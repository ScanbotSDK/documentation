{"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"In live mode input images are expected to come from a video source like a camera."},{"type":"text","text":" "},{"type":"text","text":"Scanners in live mode typically spend little time on each image and are able to quickly analyze multiple images and combine the individual image results into a final result."},{"type":"text","text":" "},{"type":"text","text":"Individual results from a particular image may be less accurate than running the scanner in single-shot mode on that frame, but after aggregating a few images of the same subject, the final result becomes much more accurate."}],"hierarchy":{"paths":[["doc:\/\/net.doo.ScanbotDocumentScannerSDK\/documentation\/ScanbotDocumentScannerSDK","doc:\/\/net.doo.ScanbotDocumentScannerSDK\/documentation\/ScanbotDocumentScannerSDK\/SBSDKProcessingMode"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/net.doo.ScanbotDocumentScannerSDK\/documentation\/ScanbotDocumentScannerSDK\/SBSDKProcessingMode\/live"},"variants":[{"paths":["\/documentation\/scanbotdocumentscannersdk\/sbsdkprocessingmode\/live"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/scanbotdocumentscannersdk\/sbsdkprocessingmode\/live"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"modules":[{"name":"ScanbotDocumentScannerSDK"}],"symbolKind":"case","role":"symbol","roleHeading":"Case","title":"SBSDKProcessingMode.live","navigatorTitle":[{"kind":"identifier","text":"SBSDKProcessingModeLive"}],"externalID":"c:@M@ScanbotDocumentScannerSDK@E@SBSDKProcessingMode@SBSDKProcessingModeLive","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"live"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"live","kind":"identifier"}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"refere